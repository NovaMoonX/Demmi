{
  "rules": {
    "sharedMeals": {
      "$shareId": {
        ".read": true,
        ".write": "auth != null && (data.child('userId').val() === auth.uid || !data.exists())",
        ".validate": "newData.hasChildren(['shareId', 'mealId', 'userId', 'title', 'category', 'ingredients', 'instructions'])",
        "userId": {
          ".validate": "newData.val() === auth.uid"
        }
      }
    },
    "$other": {
      ".read": false,
      ".write": false
    }
  }
}
